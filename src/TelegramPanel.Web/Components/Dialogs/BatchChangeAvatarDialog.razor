@namespace TelegramPanel.Web.Components.Dialogs
@inject AccountManagementService AccountManagement
@inject TelegramPanel.Core.Services.Telegram.AccountTelegramToolsService AccountTelegramTools
@inject TelegramPanel.Core.Services.AccountRiskService RiskService
@inject ImageAssetStorageService AssetStorage
@inject TemplateRenderingService TemplateRendering
@inject DataDictionaryService DictionaryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using Microsoft.AspNetCore.Components.Forms
@using TelegramPanel.Data.Entities

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                将对选中的账号批量修改头像。支持固定上传单个头像，或选择图片字典变量按字典读取方式为每个账号取图。
            </MudAlert>

            <MudText Typo="Typo.subtitle2">账号数量：@accounts.Count</MudText>

            <MudSelect T="string" @bind-Value="avatarSource" Label="头像来源" Variant="Variant.Outlined">
                <MudSelectItem Value="@AvatarSourceFixed">固定上传</MudSelectItem>
                <MudSelectItem Value="@AvatarSourceDictionary">图片字典变量</MudSelectItem>
            </MudSelect>

            @if (IsFixedSource)
            {
                <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="OnAvatarChanged" Accept="image/*" MaximumFileCount="1">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Image">
                            选择头像图片
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>

                @if (fixedAvatarBytes is { Length: > 0 })
                {
                    <MudText Typo="Typo.body2">已选择：@fixedAvatarFileName（@fixedAvatarBytes.Length bytes）</MudText>
                }
            }
            else
            {
                <MudSelect T="string" @bind-Value="selectedImageDictionaryName" Label="图片字典" Variant="Variant.Outlined">
                    <MudSelectItem Value="@string.Empty">-- 请选择图片字典 --</MudSelectItem>
                    @foreach (var item in imageDictionaryOptions)
                    {
                        <MudSelectItem Value="@item.Name">@item.DisplayText</MudSelectItem>
                    }
                </MudSelect>

                @if (imageDictionaryOptions.Count > 0)
                {
                    <MudText Typo="Typo.caption">可用图片变量：@string.Join("、", imageDictionaryOptions.Select(x => $"{{{x.Name}}}"))</MudText>
                }
            }

            @if (running || results.Count > 0)
            {
                <MudDivider Class="my-2" />

                <MudStack direction="Row" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2">进度：@processed / @accounts.Count</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Success">成功：@success</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Error">失败：@failed</MudText>
                    @if (running)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    }
                </MudStack>

                <MudTable Items="@results" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>账号</MudTh>
                        <MudTh>头像来源</MudTh>
                        <MudTh>结果</MudTh>
                        <MudTh>原因</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="账号">@context.Phone</MudTd>
                        <MudTd DataLabel="头像来源">@context.Source</MudTd>
                        <MudTd DataLabel="结果">
                            <MudChip T="string" Size="Size.Small" Color="@(context.Success ? Color.Success : Color.Error)">
                                @(context.Success ? "成功" : "失败")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="原因">@((context.Error ?? "").Trim())</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Disabled="@running">关闭</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Start" Disabled="@running">
            @if (running)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>执行中...</span>
            }
            else
            {
                <span>开始修改</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    private const string AvatarSourceFixed = "fixed";
    private const string AvatarSourceDictionary = "dictionary";

    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public IReadOnlyList<int> AccountIds { get; set; } = Array.Empty<int>();

    private List<Account> accounts = new();
    private List<ImageDictionaryOption> imageDictionaryOptions = new();

    private string avatarSource = AvatarSourceFixed;
    private string selectedImageDictionaryName = string.Empty;
    private byte[]? fixedAvatarBytes;
    private string fixedAvatarFileName = "avatar.jpg";

    private bool running;
    private int processed;
    private int success;
    private int failed;
    private readonly List<ResultRow> results = new();

    private bool IsFixedSource => string.Equals(avatarSource, AvatarSourceFixed, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var ids = AccountIds?.Distinct().Where(x => x > 0).ToList() ?? new List<int>();
        if (ids.Count == 0)
            return;

        var all = await AccountManagement.GetAllAccountsAsync();
        accounts = all.Where(a => ids.Contains(a.Id)).OrderBy(a => a.Id).ToList();

        var dictionaries = await DictionaryService.GetAllAsync();
        imageDictionaryOptions = dictionaries
            .Where(x => x.IsEnabled && string.Equals(x.Type, DataDictionaryTypes.Image, StringComparison.OrdinalIgnoreCase))
            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .Select(x => new ImageDictionaryOption(x.Name, GetReadModeText(x.ReadMode)))
            .ToList();
    }

    private async Task OnAvatarChanged(IReadOnlyList<IBrowserFile> files)
    {
        var file = files?.FirstOrDefault();
        if (file == null)
        {
            fixedAvatarBytes = null;
            fixedAvatarFileName = "avatar.jpg";
            return;
        }

        try
        {
            const long maxBytes = 20 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            fixedAvatarBytes = memory.ToArray();
            fixedAvatarFileName = string.IsNullOrWhiteSpace(file.Name) ? "avatar.jpg" : file.Name.Trim();
            avatarSource = AvatarSourceFixed;
        }
        catch (Exception ex)
        {
            fixedAvatarBytes = null;
            fixedAvatarFileName = "avatar.jpg";
            Snackbar.Add($"读取头像失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task Start()
    {
        if (running)
            return;

        if (accounts.Count == 0)
        {
            Snackbar.Add("未选择账号", Severity.Warning);
            return;
        }

        if (IsFixedSource)
        {
            if (fixedAvatarBytes is not { Length: > 0 })
            {
                Snackbar.Add("请先上传固定头像", Severity.Warning);
                return;
            }
        }
        else if (string.IsNullOrWhiteSpace(selectedImageDictionaryName))
        {
            Snackbar.Add("请选择图片字典", Severity.Warning);
            return;
        }

        var batchCheck = RiskService.CheckBatchAccounts(accounts);
        if (batchCheck.HasRiskyAccounts)
        {
            var parameters = new DialogParameters
            {
                ["Message"] = $"检测到 {batchCheck.RiskyCount} 个风险账号",
                ["DetailedMessage"] = batchCheck.GetRiskySummary(),
                ["ShowRecommendations"] = true,
                ["ShowExcludeOption"] = true,
                ["RiskyAccounts"] = batchCheck.RiskyAccounts.ToList()
            };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
            var dialog = DialogService.Show<TelegramPanel.Web.Components.Dialogs.RiskWarningDialog>("批量操作风控警告", parameters, options);
            var result = await dialog.Result;

            if (result?.Canceled ?? true)
                return;

            if (result.Data is TelegramPanel.Core.Services.RiskWarningAction action && action == TelegramPanel.Core.Services.RiskWarningAction.ExcludeRisky)
            {
                accounts = batchCheck.SafeAccounts.ToList();
                if (accounts.Count == 0)
                {
                    Snackbar.Add("排除风险账号后无剩余账号", Severity.Info);
                    return;
                }
            }
        }

        var sourceSummary = IsFixedSource ? "固定头像" : $"图片字典变量 {{{selectedImageDictionaryName}}}";
        bool? confirm = await DialogService.ShowMessageBox(
            "确认修改",
            $"将对 {accounts.Count} 个账号批量修改头像（来源：{sourceSummary}）。是否继续？",
            yesText: "继续", cancelText: "取消");

        if (confirm != true)
            return;

        running = true;
        processed = 0;
        success = 0;
        failed = 0;
        results.Clear();

        try
        {
            foreach (var account in accounts)
            {
                string source;
                bool ok;
                string? err;

                try
                {
                    if (IsFixedSource)
                    {
                        source = fixedAvatarFileName;
                        await using var stream = new MemoryStream(fixedAvatarBytes!, writable: false);
                        (ok, err) = await AccountTelegramTools.UpdateProfilePhotoAsync(account.Id, stream, fixedAvatarFileName, CancellationToken.None);
                    }
                    else
                    {
                        var token = $"{{{selectedImageDictionaryName}}}";
                        var asset = await TemplateRendering.ResolveImageTemplateAsync(token, CancellationToken.None);
                        source = $"{token} → {asset.FileName}";
                        await using var stream = await AssetStorage.OpenReadAsync(asset.AssetPath, CancellationToken.None);
                        (ok, err) = await AccountTelegramTools.UpdateProfilePhotoAsync(account.Id, stream, asset.FileName, CancellationToken.None);
                    }
                }
                catch (Exception ex)
                {
                    source = IsFixedSource ? fixedAvatarFileName : $"{{{selectedImageDictionaryName}}}";
                    ok = false;
                    err = ex.Message;
                }

                processed++;
                if (ok)
                    success++;
                else
                    failed++;

                results.Add(new ResultRow(account.DisplayPhone, source, ok, err));
                StateHasChanged();
            }

            Snackbar.Add($"头像批量修改完成：成功 {success}/{accounts.Count}，失败 {failed}/{accounts.Count}", failed == 0 ? Severity.Success : Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"执行失败：{ex.Message}", Severity.Error);
        }
        finally
        {
            running = false;
        }
    }

    private static string GetReadModeText(string? readMode)
    {
        return string.Equals(readMode, DataDictionaryReadModes.Queue, StringComparison.OrdinalIgnoreCase)
            ? "轮询"
            : "随机";
    }

    private void Cancel() => MudDialog.Close();

    private sealed record ImageDictionaryOption(string Name, string ReadMode)
    {
        public string DisplayText => $"{Name}（{ReadMode}）";
    }

    private sealed record ResultRow(string Phone, string Source, bool Success, string? Error);
}
