@namespace TelegramPanel.Web.Components.Dialogs
@inject GroupManagementService GroupManagement
@inject ISnackbar Snackbar
@using TelegramPanel.Data.Entities

<MudDialog>
    <DialogContent>
        @if (loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">共 @memberships.Count 个群组</MudText>

                @if (memberships.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">该账号当前没有已同步的群组记录</MudAlert>
                }
                else
                {
                    <MudTable Items="@memberships" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>群组名称</MudTh>
                            <MudTh>用户名</MudTh>
                            <MudTh>角色</MudTh>
                            <MudTh>群组分类</MudTh>
                            <MudTh>成员数</MudTh>
                            <MudTh>最后同步</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="群组名称">@context.Group.Title</MudTd>
                            <MudTd DataLabel="用户名">@FormatUsername(context.Group.Username)</MudTd>
                            <MudTd DataLabel="角色">
                                <MudChip T="string" Size="Size.Small" Color="@GetRoleColor(context)">@GetRoleLabel(context)</MudChip>
                            </MudTd>
                            <MudTd DataLabel="群组分类">@(context.Group.Category?.Name ?? "未分类")</MudTd>
                            <MudTd DataLabel="成员数">@context.Group.MemberCount</MudTd>
                            <MudTd DataLabel="最后同步"><PanelTime Value="context.SyncedAt" /></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Close">关闭</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int AccountId { get; set; }

    private bool loading = true;
    private List<AccountGroup> memberships = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            memberships = (await GroupManagement.GetAccountGroupMembershipsAsync(AccountId))
                .Where(x => x.Group != null)
                .OrderByDescending(x => x.IsCreator)
                .ThenByDescending(x => x.IsAdmin)
                .ThenByDescending(x => x.SyncedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载账号群组关系失败：{ex.Message}", Severity.Error);
            memberships.Clear();
        }
        finally
        {
            loading = false;
        }
    }

    private static string FormatUsername(string? username)
    {
        return string.IsNullOrWhiteSpace(username) ? "-" : "@" + username.Trim();
    }

    private static string GetRoleLabel(AccountGroup membership)
    {
        if (membership.IsCreator)
            return "创建者";
        if (membership.IsAdmin)
            return "管理员";
        return "成员";
    }

    private static Color GetRoleColor(AccountGroup membership)
    {
        if (membership.IsCreator)
            return Color.Success;
        if (membership.IsAdmin)
            return Color.Info;
        return Color.Default;
    }

    private void Close()
    {
        MudDialog.Close();
    }
}

