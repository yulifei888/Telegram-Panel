@namespace TelegramPanel.Web.Components.Dialogs
@inject BatchTaskManagementService TaskManagement
@inject ScheduledTaskService ScheduledTaskManagement
@inject TelegramPanel.Web.Modules.ModuleContributionRegistry Contributions
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using TelegramPanel.Data.Entities
@using TelegramPanel.Modules
@using TelegramPanel.Web.Modules
@using TelegramPanel.Web.Services

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                立即执行会创建一条后台执行记录；Cron 计划会在任务中心的【计划任务】区域持续调度。
            </MudAlert>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="selectedCategory" Label="任务分类" Variant="Variant.Outlined" Dense="true">
                        @foreach (var c in AvailableCategories)
                        {
                            <MudSelectItem Value="@c">@GetCategoryDisplayName(c)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="selectedTaskType" Label="任务类型" Variant="Variant.Outlined" Dense="true">
                        @foreach (var opt in AvailableOptions)
                        {
                            <MudSelectItem Value="@opt.TaskType">@opt.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudRadioGroup T="string" @bind-Value="submissionMode">
                <MudRadio T="string" Value="@SubmissionModes.Once">立即执行</MudRadio>
                <MudRadio T="string" Value="@SubmissionModes.Scheduled">Cron 计划</MudRadio>
            </MudRadioGroup>

            @if (!string.IsNullOrWhiteSpace(CurrentOption?.Description))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@CurrentOption.Description</MudText>
            }

            @if (IsScheduledMode)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Cron 按服务器本地时区解析：<b>@TimeZoneInfo.Local.Id</b>
                </MudAlert>

                <MudTextField @bind-Value="cronExpression"
                              Label="Cron 表达式"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              HelperText="5 段格式：分 时 日 月 周，例如：0 9 * * *" />

                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    @foreach (var preset in CronPresets)
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => ApplyCronPreset(preset.Expression))">
                            @preset.Label
                        </MudButton>
                    }
                </MudStack>
            }

            @if (CurrentOption != null && !string.IsNullOrWhiteSpace(CurrentOption.CreateRoute))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    该任务建议使用配置窗口创建/编辑：<b>@CurrentOption.CreateRoute</b>
                </MudAlert>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenCreateDialog(CurrentOption.CreateRoute!))">
                        打开窗口
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => NavigateTo(CurrentOption.CreateRoute!))">
                        前往页面
                    </MudButton>
                </MudStack>
            }
            else if (CurrentOption != null && !string.IsNullOrWhiteSpace(CurrentOption.EditorComponentType) && editorComponentType != null)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    该任务由模块提供自定义配置表单。
                </MudAlert>

                <DynamicComponent Type="editorComponentType" Parameters="editorParameters" />

                @if (!string.IsNullOrWhiteSpace(editorDraft.ValidationError))
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@editorDraft.ValidationError</MudText>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    该任务类型暂无专用创建表单。你可以填写通用配置（JSON 字符串）提交任务；对应模块需要在后台实现该 TaskType 的执行器。
                </MudAlert>

                <MudTextField @bind-Value="genericConfigJson"
                              Label="任务配置（JSON）"
                              Variant="Variant.Outlined"
                              Lines="8"
                              HelperText="模块可自行解析该 JSON。若无需配置可留空。" />

                <MudNumericField T="int"
                                 @bind-Value="genericTotal"
                                 Label="总数（Total，可选）"
                                 Variant="Variant.Outlined"
                                 Min="0"
                                 Max="1000000"
                                 HelperText="用于进度条展示；若不确定可填 0，由执行器在运行时持续更新进度。" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Disabled="@creating">关闭</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Create" Disabled="@creating">
            @if (creating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>提交中...</span>
            }
            else if (IsScheduledMode)
            {
                <span>保存计划</span>
            }
            else
            {
                <span>提交任务</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    private sealed record CronPresetItem(string Label, string Expression);

    private static class SubmissionModes
    {
        public const string Once = "once";
        public const string Scheduled = "scheduled";
    }

    private static readonly IReadOnlyList<CronPresetItem> CronPresets = new[]
    {
        new CronPresetItem("每30分钟", "*/30 * * * *"),
        new CronPresetItem("每小时", "0 * * * *"),
        new CronPresetItem("每天9点", "0 9 * * *"),
        new CronPresetItem("每天12点", "0 12 * * *"),
        new CronPresetItem("每天21点", "0 21 * * *")
    };

    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;

    private string _selectedCategory = string.Empty;
    private string selectedCategory
    {
        get => _selectedCategory;
        set
        {
            value = (value ?? string.Empty).Trim();
            if (string.Equals(_selectedCategory, value, StringComparison.OrdinalIgnoreCase))
                return;

            _selectedCategory = value;
            EnsureTaskTypeValid();
        }
    }

    private string _selectedTaskType = string.Empty;
    private string selectedTaskType
    {
        get => _selectedTaskType;
        set
        {
            value = (value ?? string.Empty).Trim();
            if (string.Equals(_selectedTaskType, value, StringComparison.OrdinalIgnoreCase))
                return;

            _selectedTaskType = value;
            ResolveEditorComponent();
        }
    }

    private string submissionMode = SubmissionModes.Once;
    private string cronExpression = "0 9 * * *";
    private bool creating;
    private string genericConfigJson = string.Empty;
    private int genericTotal;
    private ModuleTaskDraft editorDraft = new(0, null, false, null);
    private Type? editorComponentType;
    private Dictionary<string, object?> editorParameters = new();

    private bool IsScheduledMode => string.Equals(submissionMode, SubmissionModes.Scheduled, StringComparison.OrdinalIgnoreCase);

    private IEnumerable<string> AvailableCategories =>
        Contributions.Tasks
            .Select(x => (x.Definition.Category ?? string.Empty).Trim())
            .Where(x => x.Length > 0)
            .Where(x => !IsSystemCategory(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<ModuleTaskDefinition> AvailableOptions =>
        Contributions.Tasks
            .Select(x => x.Definition)
            .Where(o => !IsSystemCategory(o.Category))
            .Where(o => string.Equals(o.Category, selectedCategory, StringComparison.OrdinalIgnoreCase))
            .OrderBy(o => o.Order)
            .ThenBy(o => o.DisplayName, StringComparer.OrdinalIgnoreCase);

    private ModuleTaskDefinition? CurrentOption =>
        !string.IsNullOrWhiteSpace(selectedTaskType)
        && Contributions.TaskTypeToDefinition.TryGetValue(selectedTaskType, out var reg)
            ? reg.Definition
            : null;

    protected override Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedCategory))
            selectedCategory = AvailableCategories.FirstOrDefault() ?? "user";

        EnsureTaskTypeValid();
        return Task.CompletedTask;
    }

    private void EnsureTaskTypeValid()
    {
        if (AvailableOptions.All(o => !string.Equals(o.TaskType, selectedTaskType, StringComparison.OrdinalIgnoreCase)))
        {
            selectedTaskType = AvailableOptions.FirstOrDefault()?.TaskType
                ?? Contributions.Tasks.FirstOrDefault(x => !IsSystemCategory(x.Definition.Category))?.Definition.TaskType
                ?? string.Empty;
        }
    }

    private static string GetCategoryDisplayName(string category) => category switch
    {
        "user" => "用户任务",
        "bot" => "Bot 任务",
        "system" => "系统任务",
        _ => string.IsNullOrWhiteSpace(category) ? "-" : category
    };

    private static bool IsSystemCategory(string? category) =>
        string.Equals((category ?? string.Empty).Trim(), "system", StringComparison.OrdinalIgnoreCase);

    private void ResolveEditorComponent()
    {
        editorComponentType = null;
        editorParameters = new Dictionary<string, object?>();
        editorDraft = new ModuleTaskDraft(0, null, false, null);

        var option = CurrentOption;
        if (option == null || string.IsNullOrWhiteSpace(option.EditorComponentType))
            return;

        if (!Contributions.TaskTypeToDefinition.TryGetValue(option.TaskType, out var reg))
            return;

        editorComponentType = ModuleTaskEditorComponentResolver.ResolveCreateEditor(reg);
        if (editorComponentType == null)
            return;

        editorParameters = new Dictionary<string, object?>
        {
            ["Draft"] = editorDraft,
            ["DraftChanged"] = EventCallback.Factory.Create<ModuleTaskDraft>(this, OnEditorDraftChanged)
        };
    }

    private void OnEditorDraftChanged(ModuleTaskDraft draft)
    {
        editorDraft = draft;
    }

    private void ApplyCronPreset(string expression)
    {
        cronExpression = expression;
    }

    private async Task Create()
    {
        if (creating)
            return;

        if (CurrentOption != null && !string.IsNullOrWhiteSpace(CurrentOption.CreateRoute))
        {
            Snackbar.Add("该任务建议使用独立页面创建，请点击“前往创建”。", Severity.Info);
            return;
        }

        string? config;
        int total;

        try
        {
            (config, total) = ResolveSubmissionDraft();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
            return;
        }

        creating = true;
        try
        {
            if (IsScheduledMode)
            {
                bool? confirm = await DialogService.ShowMessageBox(
                    "确认创建计划任务",
                    $"将保存计划任务：{selectedTaskType}，Cron：{cronExpression}。是否继续？",
                    yesText: "继续", cancelText: "取消");

                if (confirm != true)
                    return;

                var scheduledTask = new ScheduledTask
                {
                    TaskType = selectedTaskType,
                    Total = total,
                    ConfigJson = config,
                    CronExpression = cronExpression.Trim(),
                    Status = ScheduledTaskStatuses.Enabled,
                    OwnedAssetScopeId = TaskAssetScopeHelper.GetAssetScopeId(config)
                };

                var created = await ScheduledTaskManagement.CreateAsync(scheduledTask);
                Snackbar.Add($"已创建计划任务 #{created.Id}（{selectedTaskType}）。", Severity.Success);
                MudDialog.Close(DialogResult.Ok(created.Id));
                return;
            }

            bool? taskConfirm = await DialogService.ShowMessageBox(
                "确认提交任务",
                $"将提交任务类型：{selectedTaskType}，总数：{total}。是否继续？",
                yesText: "继续", cancelText: "取消");

            if (taskConfirm != true)
                return;

            var task = new BatchTask
            {
                TaskType = selectedTaskType,
                Total = total,
                Completed = 0,
                Failed = 0,
                Config = config
            };

            var createdTask = await TaskManagement.CreateTaskAsync(task);
            Snackbar.Add($"已提交后台任务 #{createdTask.Id}（{selectedTaskType}）。请到【任务中心】查看进度。", Severity.Success);
            MudDialog.Close(DialogResult.Ok(createdTask.Id));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"提交失败：{ex.Message}", Severity.Error);
        }
        finally
        {
            creating = false;
        }
    }

    private (string? Config, int Total) ResolveSubmissionDraft()
    {
        if (string.IsNullOrWhiteSpace(selectedTaskType))
            throw new InvalidOperationException("请先选择任务类型");

        if (IsScheduledMode && string.IsNullOrWhiteSpace(cronExpression))
            throw new InvalidOperationException("请填写 Cron 表达式");

        if (editorComponentType != null)
        {
            if (!editorDraft.CanSubmit)
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(editorDraft.ValidationError) ? "请先完善任务配置" : editorDraft.ValidationError!);

            var editorConfig = string.IsNullOrWhiteSpace(editorDraft.Config) ? null : editorDraft.Config.Trim();
            if (!string.IsNullOrWhiteSpace(editorConfig))
                JsonDocument.Parse(editorConfig);

            return (editorConfig, Math.Max(0, editorDraft.Total));
        }

        var genericConfig = string.IsNullOrWhiteSpace(genericConfigJson) ? null : genericConfigJson.Trim();
        if (!string.IsNullOrWhiteSpace(genericConfig))
            JsonDocument.Parse(genericConfig);

        return (genericConfig, Math.Max(0, genericTotal));
    }

    private void NavigateTo(string url)
    {
        MudDialog.Close();
        Navigation.NavigateTo(url);
    }

    private async Task OpenCreateDialog(string route)
    {
        route = (route ?? string.Empty).Trim();
        if (route.Length == 0)
            return;

        if (!TryParseExtRoute(route, out var moduleId, out var pageKey))
        {
            Snackbar.Add("该任务未提供可窗口打开的模块页面，请使用“前往页面”。", Severity.Info);
            return;
        }

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraLarge, FullWidth = true };
        var parameters = new DialogParameters
        {
            ["ModuleId"] = moduleId,
            ["PageKey"] = pageKey
        };

        DialogService.Show<TelegramPanel.Web.Components.Dialogs.ModulePageDialog>("任务配置", parameters, options);
        await Task.CompletedTask;
    }

    private static bool TryParseExtRoute(string route, out string moduleId, out string pageKey)
    {
        moduleId = string.Empty;
        pageKey = string.Empty;

        route = (route ?? string.Empty).Trim();
        if (!route.StartsWith("/ext/", StringComparison.OrdinalIgnoreCase))
            return false;

        var parts = route.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length < 3 || !string.Equals(parts[0], "ext", StringComparison.OrdinalIgnoreCase))
            return false;

        moduleId = parts[1];
        pageKey = parts[2];
        return moduleId.Length > 0 && pageKey.Length > 0;
    }

    private void Cancel() => MudDialog.Close();
}
