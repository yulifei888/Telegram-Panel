    private async Task DeleteSelectedGroups()
    {
        var targets = selectedGroups.ToList();
        if (targets.Count == 0)
        {
            Snackbar.Add("未选择任何群组", Severity.Info);
            return;
        }

        bool? result = await DialogService.ShowMessageBox(
            "确认删除",
            $"确定要删除选中的 {targets.Count} 个群组吗？此操作不可恢复。",
            yesText: "删除", cancelText: "取消");

        if (result != true)
            return;

        loading = true;
        try
        {
            foreach (var group in targets)
                await GroupManagement.DeleteGroupAsync(group.Id);

            selectedGroups.Clear();
            await ReloadTable();
            Snackbar.Add($"删除成功：{targets.Count} 个群组", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"删除失败：{ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DeleteGroup(int id)
    {
        var group = groups.FirstOrDefault(g => g.Id == id);
        if (group == null)
            return;

        bool? result = await DialogService.ShowMessageBox(
            "确认删除",
            $"确定要删除群组 {group.Title} 吗？此操作不可恢复。",
            yesText: "删除", cancelText: "取消");

        if (result == true)
        {
            try
            {
                await GroupManagement.DeleteGroupAsync(id);
                await ReloadTable();
                Snackbar.Add("删除成功", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败：{ex.Message}", Severity.Error);
            }
        }
    }
