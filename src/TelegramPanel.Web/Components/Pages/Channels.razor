    private async Task OpenBatchSetGroupSelected()
    {
        var targets = selectedChannels.ToList();
        if (targets.Count == 0)
        {
            Snackbar.Add("未选择任何频道", Severity.Info);
            return;
        }

        if (groups.Count == 0)
            await LoadGroups();

        var parameters = new DialogParameters
        {
            ["Groups"] = groups,
            ["SelectedCount"] = targets.Count
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<BatchSetChannelGroupDialog>("批量修改分类", parameters, options);
        var result = await dialog.Result;
        if (result is not { Canceled: false })
            return;

        var groupIdRaw = result.Data is int x ? x : 0;
        int? groupId = groupIdRaw <= 0 ? null : groupIdRaw;

        loading = true;
        try
        {
            foreach (var c in targets)
                await ChannelManagement.UpdateChannelGroupAsync(c.Id, groupId);

            selectedChannels.Clear();
            await ReloadTable();
            Snackbar.Add($"分类已更新：{targets.Count} 个频道", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"修改分类失败：{ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task KickUser(Channel channel)
    {
        // 复用详情弹窗里的“踢人”能力，减少重复 UI
        await ShowDetails(channel);
    }

    private async Task CopyLinkAsync(Channel channel)
    {
        try
        {
            var executeAccountId = await ResolveChannelExecuteAccountIdAsync(channel);
            if (executeAccountId is not > 0)
            {
                Snackbar.Add("无法导出链接：该频道暂无可用执行账号，请先同步对应账号的频道数据", Severity.Warning);
                return;
            }

            var link = await ChannelService.ExportJoinLinkAsync(executeAccountId.Value, channel.TelegramId);

            await JS.InvokeVoidAsync("telegramPanel.copyText", link);
            Snackbar.Add("已复制链接", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"复制失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task<int?> ResolveChannelExecuteAccountIdAsync(Channel channel)
    {
        return await ChannelManagement.ResolveExecuteAccountIdAsync(
            channel,
            preferredAccountId: filterAccount > 0 ? filterAccount : null);
    }

    private async Task<int?> ResolveChannelDisbandAccountIdAsync(Channel channel)
    {
        if (filterAccount > 0 && channel.CreatorAccountId == filterAccount)
            return filterAccount;

        if (channel.CreatorAccountId is > 0)
            return channel.CreatorAccountId.Value;

        return await ResolveChannelExecuteAccountIdAsync(channel);
    }

    private async Task<bool> ConfirmAdminPasswordAsync(string prompt, string confirmText)
    {
        var parameters = new DialogParameters
        {
            ["Prompt"] = prompt,
            ["ConfirmText"] = confirmText
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<AdminPasswordConfirmDialog>("后台密码确认", parameters, options);
        var result = await dialog.Result;
        return result is { Canceled: false };
    }

    private void ShowBatchFailureWarnings(IReadOnlyList<string> failures, string actionName)
    {
        foreach (var failure in failures.Take(3))
            Snackbar.Add($"{actionName}失败：{failure}", Severity.Warning);

        if (failures.Count > 3)
            Snackbar.Add($"另有 {failures.Count - 3} 条{actionName}失败，请重试或逐个处理", Severity.Warning);
    }

    private async Task LeaveChannel(Channel channel)
    {
        bool? result = await DialogService.ShowMessageBox(
            "确认退出",
            $"确定要让执行账号退出频道 {channel.Title} 吗？若系统内其他账号仍在该频道中，频道记录可能继续显示。",
            yesText: "退出", cancelText: "取消");

        if (result != true)
            return;

        try
        {
            var executeAccountId = await ResolveChannelExecuteAccountIdAsync(channel);
            if (executeAccountId is not > 0)
            {
                Snackbar.Add("退出失败：该频道暂无可用执行账号", Severity.Warning);
                return;
            }

            await ChannelService.LeaveChannelAsync(executeAccountId.Value, channel.TelegramId);
            await ChannelManagement.RemoveAccountChannelAsync(channel.Id, executeAccountId.Value);
            await ReloadTable();
            Snackbar.Add($"已退出频道：{channel.Title}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"退出失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task LeaveSelectedChannels()
    {
        var targets = selectedChannels.ToList();
        if (targets.Count == 0)
        {
            Snackbar.Add("未选择任何频道", Severity.Info);
            return;
        }

        bool? result = await DialogService.ShowMessageBox(
            "确认批量退出",
            $"确定要让执行账号退出选中的 {targets.Count} 个频道吗？若系统内其他账号仍在这些频道中，频道记录可能继续显示。",
            yesText: "退出", cancelText: "取消");

        if (result != true)
            return;

        loading = true;
        var successCount = 0;
        var failures = new List<string>();
        try
        {
            foreach (var channel in targets)
            {
                try
                {
                    var executeAccountId = await ResolveChannelExecuteAccountIdAsync(channel);
                    if (executeAccountId is not > 0)
                        throw new InvalidOperationException("暂无可用执行账号");

                    await ChannelService.LeaveChannelAsync(executeAccountId.Value, channel.TelegramId);
                    await ChannelManagement.RemoveAccountChannelAsync(channel.Id, executeAccountId.Value);
                    successCount++;
                }
                catch (Exception ex)
                {
                    failures.Add($"{channel.Title}：{ex.Message}");
                }
            }

            selectedChannels.Clear();
            await ReloadTable();
            Snackbar.Add(
                $"批量退出完成：成功 {successCount} 个，失败 {failures.Count} 个",
                failures.Count == 0 ? Severity.Success : successCount > 0 ? Severity.Warning : Severity.Error);
            ShowBatchFailureWarnings(failures, "退出频道");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DisbandChannel(Channel channel)
    {
        var confirmed = await ConfirmAdminPasswordAsync(
            $"确定要解散频道 {channel.Title} 吗？此操作会在 Telegram 侧删除频道，并从本地面板移除记录。",
            "确认解散");
        if (!confirmed)
            return;

        try
        {
            var executeAccountId = await ResolveChannelDisbandAccountIdAsync(channel);
            if (executeAccountId is not > 0)
            {
                Snackbar.Add("解散失败：该频道暂无可用执行账号", Severity.Warning);
                return;
            }

            await ChannelService.DisbandChannelAsync(executeAccountId.Value, channel.TelegramId);
            await ChannelManagement.DeleteChannelAsync(channel.Id);
            await ReloadTable();
            Snackbar.Add($"已解散频道：{channel.Title}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"解散失败：{ex.Message}", Severity.Error);
        }
    }

