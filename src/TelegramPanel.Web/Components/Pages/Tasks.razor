@page "/tasks"
@inject BatchTaskManagementService TaskManagement
@inject ScheduledTaskService ScheduledTaskManagement
@inject ImageAssetStorageService AssetStorage
@inject TelegramPanel.Web.Modules.ModuleContributionRegistry Contributions
@inject IEnumerable<IModuleTaskRerunBuilder> TaskRerunBuilders
@inject PanelTimeZoneService TimeZone
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using TelegramPanel.Data.Entities
@using TelegramPanel.Core.BatchTasks
@using System.Text.Json
@using TelegramPanel.Modules
@using TelegramPanel.Web.Modules
@using TelegramPanel.Web.Services
@implements IDisposable

<PageTitle>任务中心 - Telegram Panel</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">任务中心</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">总任务数 (@tasks.Count)</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" Size="Size.Small"
                           Disabled="@loading" OnClick="@(async (MouseEventArgs _) => await LoadTasks())" />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddTask"
                       Disabled="@loading" OnClick="OpenCreateTaskDialog">
                新建任务
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep"
                       Disabled="@(loading || tasks.Count == 0)" OnClick="ClearAllTasks">
                清理全部任务
            </MudButton>
            <MudSelect @bind-Value="filterCategory" Label="任务分类" Variant="Variant.Outlined" Dense="true" Style="min-width: 140px;">
                <MudSelectItem Value='@("all")'>全部</MudSelectItem>
                @foreach (var c in AvailableCategories)
                {
                    <MudSelectItem Value="@c">@GetCategoryDisplayName(c)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="historyStatusFilter" Label="历史状态" Variant="Variant.Outlined" Dense="true" Style="min-width: 120px;">
                <MudSelectItem Value='@("all")'>全部</MudSelectItem>
                <MudSelectItem Value='@("completed")'>已完成</MudSelectItem>
                <MudSelectItem Value='@("failed")'>失败</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudTable Items="@scheduledTasks" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading">
            <ToolBarContent>
                <MudText Typo="Typo.h6">计划任务 (@scheduledTasks.Count)</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>归属</MudTh>
                <MudTh>任务类型</MudTh>
                <MudTh>状态</MudTh>
                <MudTh>Cron</MudTh>
                <MudTh>下次运行</MudTh>
                <MudTh>上次运行</MudTh>
                <MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="归属">
                    <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.TaskType)">@GetCategoryName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="任务类型">
                    <MudChip T="string" Size="Size.Small" Icon="@GetTaskIcon(context.TaskType)">@GetTaskTypeName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="状态">
                    <MudChip T="string" Size="Size.Small" Color="@GetScheduledStatusColor(context.Status)">@GetScheduledStatusName(context.Status)</MudChip>
                </MudTd>
                <MudTd DataLabel="Cron">
                    <MudText Typo="Typo.body2">@context.CronExpression</MudText>
                    <MudText Typo="Typo.caption">时区：@TimeZone.Current.Id</MudText>
                </MudTd>
                <MudTd DataLabel="下次运行">
                    @if (context.NextRunAtUtc.HasValue)
                    {
                        <PanelTime Value="context.NextRunAtUtc.Value" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </MudTd>
                <MudTd DataLabel="上次运行">
                    @if (context.LastRunAtUtc.HasValue)
                    {
                        <PanelTime Value="context.LastRunAtUtc.Value" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </MudTd>
                <MudTd DataLabel="操作">
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info"
                                   OnClick="@(() => ShowScheduledTaskDetails(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => OpenEditScheduledTask(context))" />
                    @if (string.Equals(context.Status, ScheduledTaskStatuses.Enabled, StringComparison.OrdinalIgnoreCase))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Pause" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => PauseScheduledTask(context))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                       OnClick="@(() => ResumeScheduledTask(context))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteScheduledTask(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>暂无计划任务</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudTable Items="@activeTasks" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading">
            <ToolBarContent>
                <MudText Typo="Typo.h6">执行中任务 (@activeTasks.Count())</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>任务ID</MudTh>
                <MudTh>归属</MudTh>
                <MudTh>任务类型</MudTh>
                <MudTh>状态</MudTh>
                <MudTh>进度</MudTh>
                <MudTh>创建时间</MudTh>
                <MudTh>完成时间</MudTh>
                <MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="任务ID">@context.Id</MudTd>
                <MudTd DataLabel="归属">
                    <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.TaskType)">@GetCategoryName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="任务类型">
                    <MudChip T="string" Size="Size.Small" Icon="@GetTaskIcon(context.TaskType)">@GetTaskTypeName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="状态">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(GetDisplayStatus(context))">@GetStatusName(GetDisplayStatus(context))</MudChip>
                </MudTd>
                <MudTd DataLabel="进度">
                    <MudProgressLinear Value="@GetProgress(context)" Color="@GetProgressColor(GetDisplayStatus(context))" />
                    <MudText Typo="Typo.caption">@context.Completed / @context.Total (@context.Failed 失败)</MudText>
                </MudTd>
                <MudTd DataLabel="创建时间"><PanelTime Value="context.CreatedAt" /></MudTd>
                <MudTd DataLabel="完成时间">
                    @if (context.CompletedAt.HasValue)
                    {
                        <PanelTime Value="context.CompletedAt.Value" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </MudTd>
                <MudTd DataLabel="操作">
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info"
                                   OnClick="@(() => ShowTaskDetails(context))" />
                    @if (CanPauseTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Pause" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => PauseTask(context))" />
                    }
                    @if (CanResumeTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                       OnClick="@(() => ResumeTask(context))" />
                    }
                    @if (CanEditTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => OpenEditTask(context))" />
                    }
                    @if (CanCancelTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => CancelTask(context.Id))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteTask(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>暂无执行中任务</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

<MudCard>
    <MudCardContent>
        <MudTable Items="@historyTasks" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading">
            <ToolBarContent>
                <MudText Typo="Typo.h6">历史任务 (@historyTasks.Count())</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>任务ID</MudTh>
                <MudTh>归属</MudTh>
                <MudTh>任务类型</MudTh>
                <MudTh>状态</MudTh>
                <MudTh>进度</MudTh>
                <MudTh>创建时间</MudTh>
                <MudTh>完成时间</MudTh>
                <MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="任务ID">@context.Id</MudTd>
                <MudTd DataLabel="归属">
                    <MudChip T="string" Size="Size.Small" Color="@GetCategoryColor(context.TaskType)">@GetCategoryName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="任务类型">
                    <MudChip T="string" Size="Size.Small" Icon="@GetTaskIcon(context.TaskType)">@GetTaskTypeName(context.TaskType)</MudChip>
                </MudTd>
                <MudTd DataLabel="状态">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(GetDisplayStatus(context))">@GetStatusName(GetDisplayStatus(context))</MudChip>
                </MudTd>
                <MudTd DataLabel="进度">
                    <MudProgressLinear Value="@GetProgress(context)" Color="@GetProgressColor(GetDisplayStatus(context))" />
                    <MudText Typo="Typo.caption">@context.Completed / @context.Total (@context.Failed 失败)</MudText>
                </MudTd>
                <MudTd DataLabel="创建时间"><PanelTime Value="context.CreatedAt" /></MudTd>
                <MudTd DataLabel="完成时间">
                    @if (context.CompletedAt.HasValue)
                    {
                        <PanelTime Value="context.CompletedAt.Value" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </MudTd>
                <MudTd DataLabel="操作">
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info"
                                   OnClick="@(() => ShowTaskDetails(context))" />
                    @if (CanEditTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => OpenEditTask(context))" />
                    }
                    @if (CanRerunTask(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small" Color="Color.Success"
                                       OnClick="@(() => RerunTask(context))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
