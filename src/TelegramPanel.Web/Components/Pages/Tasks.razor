    private async Task DeleteTask(BatchTask task)
    {
        var status = GetDisplayStatus(task);
        var isActive = IsActiveStatus(status);
        var message = isActive
            ? $"确定要删除任务 #{task.Id} 吗？删除后将停止后台执行并移除记录，此操作不可恢复。"
            : $"确定要删除任务 #{task.Id} 的记录吗？此操作不可恢复。";

        bool? result = await DialogService.ShowMessageBox(
            "确认删除",
            message,
            yesText: "删除", cancelText: "取消");

        if (result == true)
        {
            try
            {
                await CleanupBatchTaskAssetsAsync(task);
                await TaskManagement.DeleteTaskAsync(task.Id);
                await LoadTasks();
                Snackbar.Add(isActive ? "任务已删除，后台执行将在下一次状态检查时停止" : "任务已删除", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除失败：{ex.Message}", Severity.Error);
            }
        }
    }

    private async Task ClearAllTasks()
    {
        var hasActive = tasks.Any(t => t.Status is "pending" or "running" or "paused");

        var parameters = new DialogParameters
        {
            ["HasActiveTasks"] = hasActive
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<TelegramPanel.Web.Components.Dialogs.TaskCleanupDialog>("确认清理", parameters, options)!;
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not string mode)
            return;

        var historyOnly = string.Equals(mode, "history", StringComparison.OrdinalIgnoreCase);

        try
        {
            var allTasks = (await TaskManagement.GetAllTasksAsync()).ToList();
            if (allTasks.Count == 0)
            {
                tasks.Clear();
                Snackbar.Add("没有可清理的任务记录", Severity.Info);
                return;
            }

            if (historyOnly)
            {
                var historyTaskList = allTasks
                    .Where(t => IsHistoryStatus(GetDisplayStatus(t)))
                    .ToList();

                if (historyTaskList.Count == 0)
                {
                    Snackbar.Add("没有可清理的历史任务记录", Severity.Info);
                    return;
                }

                foreach (var item in historyTaskList)
                {
                    await CleanupBatchTaskAssetsAsync(item);
                    await TaskManagement.DeleteTaskAsync(item.Id);
                }

                Snackbar.Add($"已清理 {historyTaskList.Count} 条历史任务记录", Severity.Success);
            }
            else
            {
                foreach (var activeTask in allTasks.Where(t => t.Status is "pending" or "running" or "paused"))
                    await TaskManagement.CompleteTaskAsync(activeTask.Id, success: false);

                foreach (var item in allTasks)
                {
                    await CleanupBatchTaskAssetsAsync(item);
                    await TaskManagement.DeleteTaskAsync(item.Id);
                }

                tasks.Clear();
                Snackbar.Add($"已清理 {allTasks.Count} 条任务记录", Severity.Success);
            }

            await LoadTasks();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"清理失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task CleanupBatchTaskAssetsAsync(BatchTask task)
    {
        var scopeId = TaskAssetScopeHelper.GetAssetScopeId(task.Config);
        if (!string.IsNullOrWhiteSpace(scopeId))
            await AssetStorage.DeleteScopeAsync(scopeId);
    }

    private void ShowScheduledTaskDetails(ScheduledTask task)
    {
        var details = $"任务类型: {GetTaskTypeName(task.TaskType)}\n" +
                      $"状态: {GetScheduledStatusName(task.Status)}\n" +
                      $"Cron: {task.CronExpression}\n" +
                      $"时区: {TimeZone.Current.Id}\n" +
                      $"总数: {task.Total}\n" +
                      $"创建时间: {TimeZone.Format(task.CreatedAt, "yyyy-MM-dd HH:mm")}\n" +
                      $"更新时间: {TimeZone.Format(task.UpdatedAt, "yyyy-MM-dd HH:mm")}\n";

        if (task.NextRunAtUtc.HasValue)
            details += $"下次运行: {TimeZone.Format(task.NextRunAtUtc.Value, "yyyy-MM-dd HH:mm")}\n";
        if (task.LastRunAtUtc.HasValue)
            details += $"上次运行: {TimeZone.Format(task.LastRunAtUtc.Value, "yyyy-MM-dd HH:mm")}\n";
        if (task.LastBatchTaskId.HasValue)
            details += $"最近批次任务: #{task.LastBatchTaskId.Value}\n";
        if (!string.IsNullOrWhiteSpace(task.ConfigJson))
            details += $"\n配置信息:\n{task.ConfigJson}";

        var html = System.Net.WebUtility.HtmlEncode(details)
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace("\n", "<br/>", StringComparison.Ordinal);
        DialogService.ShowMessageBox("计划任务详情", (MarkupString)html);
    }

