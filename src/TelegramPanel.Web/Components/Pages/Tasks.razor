    private async Task RerunTask(BatchTask task)
    {
        if (!CanRerunTask(task))
        {
            Snackbar.Add("该任务当前不可重新运行", Severity.Warning);
            return;
        }

        bool? confirm = await DialogService.ShowMessageBox(
            "确认重新运行",
            $"将基于任务 #{task.Id} 的配置创建一个新任务，是否继续？",
            yesText: "继续", cancelText: "取消");

        if (confirm != true)
            return;

        try
        {
            var request = BuildRerunRequest(task);
            var created = await TaskManagement.CreateTaskAsync(CreateBatchTaskFromRequest(request));
            Snackbar.Add($"已创建重跑任务 #{created.Id}", Severity.Success);
            await LoadTasks();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"重新运行失败：{ex.Message}", Severity.Error);
        }
    }

    private ModuleTaskCreateRequest BuildRerunRequest(BatchTask task)
    {
        var taskType = (task.TaskType ?? string.Empty).Trim();
        if (taskType.Length == 0)
            throw new InvalidOperationException("任务类型为空，无法重新运行");

        var builder = TaskRerunBuilders.FirstOrDefault(x =>
            string.Equals((x.TaskType ?? string.Empty).Trim(), taskType, StringComparison.OrdinalIgnoreCase));

        if (builder != null)
        {
            var request = builder.Build(CreateTaskSnapshot(task));
            return NormalizeCreateRequest(request);
        }

        return new ModuleTaskCreateRequest
        {
            TaskType = taskType,
            Total = Math.Max(0, task.Total),
            Config = NormalizeNullableText(task.Config)
        };
    }

    private static ModuleTaskCreateRequest NormalizeCreateRequest(ModuleTaskCreateRequest? request)
    {
        if (request == null)
            throw new InvalidOperationException("重跑构建结果为空");

        var taskType = (request.TaskType ?? string.Empty).Trim();
        if (taskType.Length == 0)
            throw new InvalidOperationException("重跑任务类型为空");

        return new ModuleTaskCreateRequest
        {
            TaskType = taskType,
            Total = Math.Max(0, request.Total),
            Config = NormalizeNullableText(request.Config)
        };
    }

    private static ModuleTaskSnapshot CreateTaskSnapshot(BatchTask task)
    {
        return new ModuleTaskSnapshot
        {
            TaskId = task.Id,
            TaskType = (task.TaskType ?? string.Empty).Trim(),
            Status = GetDisplayStatus(task),
            Total = Math.Max(0, task.Total),
            Completed = Math.Max(0, task.Completed),
            Failed = Math.Max(0, task.Failed),
            Config = NormalizeNullableText(task.Config)
        };
    }

    private static BatchTask CreateBatchTaskFromRequest(ModuleTaskCreateRequest request)
    {
        var normalized = NormalizeCreateRequest(request);
        return new BatchTask
        {
            TaskType = normalized.TaskType,
            Total = normalized.Total,
            Completed = 0,
            Failed = 0,
            Config = normalized.Config
        };
    }
