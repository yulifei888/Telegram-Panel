        if (!result.Canceled && result.Data is BotBanMemberDialog.BanUserRequest request)
        {
            loading = true;
            try
            {
                if (request.UseAccountExecution)
                    await ExecuteBanByAccountAsync(request);
                else
                    await ExecuteBanByBotAsync(request);

                selected.Clear();
            }
            catch (Exception ex)
            {
