    private async Task ExecuteBanByBotAsync(BotBanMemberDialog.BanUserRequest request)
    {
        if (request.UserId is null or <= 0)
        {
            Snackbar.Add("机器人执行仅支持用户 ID（纯数字）", Severity.Warning);
            return;
        }

        var channelTelegramIds = selected.Select(x => x.TelegramId).Distinct().ToList();
        var banResult = await BotTelegram.BanChatMemberAsync(
            selectedBotId,
            channelTelegramIds,
            request.UserId.Value,
            request.PermanentBan,
            CancellationToken.None);

        var actionText = request.PermanentBan ? "封禁" : "踢出";
        if (banResult.Failures.Count == 0)
        {
            Snackbar.Add($"已成功从 {banResult.SuccessCount} 个频道{actionText}用户 {request.UserId}", Severity.Success);
            return;
        }

        var message = $"成功：{banResult.SuccessCount} 个，失败：{banResult.Failures.Count} 个";
        if (banResult.Failures.Count > 0)
        {
            var firstError = banResult.Failures.First();
            message += $"（首个失败原因：{firstError.Value}）";
        }
        Snackbar.Add(message, Severity.Warning);
    }

    private async Task ExecuteBanByAccountAsync(BotBanMemberDialog.BanUserRequest request)
    {
        var targetChannels = selected
            .Where(x => x != null)
            .GroupBy(x => x.TelegramId)
            .Select(x => x.First())
            .ToList();
        if (targetChannels.Count == 0)
            return;

        if (string.IsNullOrWhiteSpace(request.Username) && (request.UserId is null or <= 0))
        {
            Snackbar.Add("账号执行需要填写 @username 或用户 ID", Severity.Warning);
            return;
        }

        var allAccounts = (await AccountManagement.GetAllAccountsAsync()).ToList();
        var availableAccounts = allAccounts
            .Where(x => x.IsActive && x.Category?.ExcludeFromOperations != true && x.UserId > 0)
            .ToList();
        var accountsById = availableAccounts.ToDictionary(x => x.Id);
        var accountsByUserId = availableAccounts
            .GroupBy(x => x.UserId)
            .ToDictionary(x => x.Key, x => x.First());

        var channelAdmins = new Dictionary<long, List<BotTelegramService.BotChatAdminInfo>>();
        foreach (var channel in targetChannels)
        {
            try
            {
                channelAdmins[channel.TelegramId] = await BotTelegram.GetChatAdminsAsync(selectedBotId, channel.TelegramId, CancellationToken.None);
            }
            catch
            {
                channelAdmins[channel.TelegramId] = new List<BotTelegramService.BotChatAdminInfo>();
            }
        }

        var failures = new Dictionary<long, string>();
        var success = 0;
        foreach (var channel in targetChannels)
        {
            var (executorId, reason) = ResolveBanExecutorAccountId(
                channel,
                request.SelectedAccountId,
                channelAdmins,
                accountsById,
                accountsByUserId);

            if (executorId == null)
            {
                failures[channel.TelegramId] = NormalizeReason(reason ?? "无可用执行账号");
                continue;
            }

            try
            {
                if (!string.IsNullOrWhiteSpace(request.Username))
                {
                    await ChannelService.KickUserAsync(executorId.Value, channel.TelegramId, request.Username!, request.PermanentBan);
                }
                else if (request.UserId > 0)
                {
                    await ChannelService.KickUserByUserIdAsync(executorId.Value, channel.TelegramId, request.UserId.Value, request.PermanentBan);
                }
                else
                {
                    throw new InvalidOperationException("缺少可用的目标用户标识");
                }

                success++;
            }
            catch (Exception ex)
            {
                failures[channel.TelegramId] = NormalizeReason(ex.Message);
            }
        }

        var actionText = request.PermanentBan ? "封禁" : "踢出";
        var targetText = !string.IsNullOrWhiteSpace(request.Username)
            ? $"@{request.Username}"
            : request.UserId?.ToString() ?? "-";

        if (failures.Count == 0)
        {
            Snackbar.Add($"已成功从 {success} 个频道{actionText}用户 {targetText}", Severity.Success);
            return;
        }

        var summary = $"成功：{success} 个，失败：{failures.Count} 个";
        if (failures.Count > 0)
        {
            var first = failures.First();
            var channelTitle = targetChannels.FirstOrDefault(x => x.TelegramId == first.Key)?.Title ?? first.Key.ToString();
            summary += $"（首个失败：{channelTitle}：{first.Value}）";
        }
        Snackbar.Add(summary, Severity.Warning);
    }

    private static (int? ExecutorId, string? Reason) ResolveBanExecutorAccountId(
        BotChannel channel,
        int selectedAccountId,
        IReadOnlyDictionary<long, List<BotTelegramService.BotChatAdminInfo>> channelAdmins,
        IReadOnlyDictionary<int, Account> accountsById,
        IReadOnlyDictionary<long, Account> accountsByUserId)
    {
        if (!channelAdmins.TryGetValue(channel.TelegramId, out var admins) || admins.Count == 0)
            return (null, "无法获取频道管理员列表（请确认 Bot 已加入且为管理员）");

        if (selectedAccountId > 0)
        {
            if (!accountsById.TryGetValue(selectedAccountId, out var selected) || selected.UserId <= 0)
                return (null, "所选执行账号无效");

            var admin = admins.FirstOrDefault(x => x.UserId == selected.UserId);
            if (admin == null)
                return (null, "所选执行账号不是该频道管理员");

            if (!admin.IsCreator && !admin.CanRestrictMembers)
                return (null, "所选执行账号缺少“封禁用户”权限");

            return (selected.Id, null);
        }

        var creator = admins.FirstOrDefault(x => x.IsCreator);
        if (creator != null && accountsByUserId.TryGetValue(creator.UserId, out var creatorAcc))
            return (creatorAcc.Id, null);

        foreach (var admin in admins)
        {
            if (!admin.IsCreator && !admin.CanRestrictMembers)
                continue;

            if (accountsByUserId.TryGetValue(admin.UserId, out var account))
                return (account.Id, null);
        }

        return (null, "无可用执行账号（需要该频道管理员且拥有“封禁用户”权限，并且在系统中存在）");
    }

    private static string NormalizeReason(string? reason)
    {
        var text = (reason ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(text) ? "失败" : text;
    }

